---
import BaseLayout from "../layouts/BaseLayout.astro";

// ─────────────────────────────────────────────────────────────
//  EDIT YOUR CV CONTENT HERE
// ─────────────────────────────────────────────────────────────
const cv = {
  name: "Tristan Weber",
  role: "AI / Machine Learning Engineer",
  tagline:
    "I build AI systems for real-world data — and, on the side, instruments that turn noise into rhythm.",
  location: "Paris, France",
  email: "webertristan2000@gmail.com",
  links: {
    github: "https://github.com/titille",
    linkedin: "https://www.linkedin.com/in/tristan-weber-173158208/",
  },

  about:
    "Applied mathematician turned ML engineer (M2, Paris 1 Panthéon-Sorbonne). I like problems where careful modelling meets a shipping product — right now, document-analysis AI at Arrago. The projects below are my playground: audio, rhythm and generative geometry. Currently open to full-time AI / ML roles.",

  experience: [
    {
      title: "AI Software Engineer",
      company: "Arrago",
      type: "Internship",
      where: "Paris",
      period: "Feb 2026 — Present",
      description:
        "Built an internal web app where sales and analysts log in to assemble and analyze reverse-mortgage (prêt viager hypothécaire) case files. Designed AI workflows that automatically pull the required documents, analyze bank statements, and flag inconsistencies across a file's paperwork.",
    },
    {
      title: "Machine Learning / Deep Learning Engineer",
      company: "Bureau Veritas — Marine & Offshore",
      type: "Internship",
      where: "Paris La Défense",
      period: "Apr 2025 — Oct 2025",
      description:
        "Time-series prediction on CFD sloshing simulations. Built ML/DL models in Python (XGBoost, MLP, LSTM) and ran training, optimization and fine-tuning with PyTorch / Keras and Optuna (hyperparameter search, validation).",
    },
    {
      title: "Data Quality / Telemetry Analyst",
      company: "RTE — Réseau de Transport d'Électricité",
      type: "Internship",
      where: "Paris La Défense",
      period: "Apr 2023 — Sep 2023",
      description:
        "Analyzed data quality and transmission losses on grid telemetry. Extracted data on Linux, then cleaned, ran consistency/completeness checks and anomaly detection in Python, reconciled missing telemetry via correlations and loss scenarios, and delivered usable datasets.",
    },
    {
      title: "Mathematics Tutor (MIASHS)",
      company: "Université Paris 1 Panthéon-Sorbonne",
      type: "Part-time",
      where: "Paris",
      period: "Sep 2020 — Apr 2023",
      description:
        "Tutored first-year MIASHS students in Analysis, Algebra, Probability and Python — methodology coaching, exercise correction and exam prep.",
    },
  ],

  projects: [
    {
      name: "Rain to Hi-Hat",
      meta: "INSTRUMENT",
      year: "2025",
      image: "/img/rain-to-hihat.png",
      description:
        "A full-screen pixel-art soundscape — physically-modeled rain, swell, storm and wind — that morphs into a drum kit with a single knob. Every visible pixel event maps to an audible one, in dependency-free vanilla JS on a real-time AudioWorklet.",
      tech: ["Web Audio", "AudioWorklet", "DSP"],
      demo: "/demos/rain-to-hihat/",
      link: null,
    },
    {
      name: "Rhythmic Spiral",
      meta: "VISUALIZER",
      year: "2025",
      image: "/img/rhythmic-spiral.png",
      description:
        "An interactive 3D visualization of one rhythm morphing into another. Beats travel as colored threads along a time-spiral, auto-matched by shortest path, driving live audio synthesis — 6 timbres, 5 scales, 30+ presets.",
      tech: ["Three.js", "JavaScript", "Web Audio"],
      demo: "/demos/rhythmic-spiral/",
      link: "https://github.com/titille/rhythmic-spiral",
    },
    {
      name: "Concentric Forms",
      meta: "GENERATIVE ART",
      year: "2026",
      image: "/img/formes-concentriques.png",
      description:
        "A seeded generative-art tool that draws concentric geometry — nested rings and circles blended across an indigo→magenta gradient. Every seed yields a new deterministic composition; sliders reshape it and any result exports to PNG.",
      tech: ["Canvas 2D", "JavaScript", "Generative art"],
      demo: "/demos/formes-concentriques/",
      link: "https://github.com/titille/formes-concentriques",
    },
  ],

  skills: [
    "Python",
    "PyTorch",
    "Keras",
    "Machine Learning",
    "Deep Learning",
    "LLMs",
    "Document AI",
    "Time-Series Forecasting",
    "XGBoost",
    "Optuna",
    "Pandas / NumPy",
    "Data Analysis",
    "JavaScript / TypeScript",
    "Web Audio / DSP",
    "Three.js",
    "Git · Linux",
  ],

  education: [
    {
      title: "M2 · Applied Mathematics & Data Science (MMMEF)",
      school: "Université Paris 1 Panthéon-Sorbonne",
      period: "2022 — 2023",
    },
    {
      title: "Bachelor's · Mathematics & Computer Science (MIASHS)",
      school: "Université Paris 1 Panthéon-Sorbonne",
      period: "2018 — 2021",
    },
  ],
};

const sections = [
  { id: "work", label: "Work" },
  { id: "about", label: "About" },
  { id: "experience", label: "Exp" },
  { id: "skills", label: "Skills" },
  { id: "education", label: "Edu" },
  { id: "contact", label: "Contact" },
];
---

<BaseLayout title={`${cv.name} — ${cv.role}`} description={cv.tagline}>
  <canvas id="sky" aria-hidden="true"></canvas>
  <div id="flash" aria-hidden="true"></div>

  <!-- Sequencer nav -->
  <nav class="seq" aria-label="Section navigation">
    {
      sections.map((s) => (
        <button data-seq={s.id} aria-label={s.label}>
          <span class="seq-label">{s.label}</span>
        </button>
      ))
    }
  </nav>

  <div class="wrap">
    <!-- Instrument bar -->
    <header class="bar">
      <div class="bar-inner">
        <a class="brand" href="#top">
          <svg class="brand-mark" width="16" height="20" viewBox="0 0 8 10" aria-hidden="true">
            <rect x="0" y="0" width="2" height="2" fill="currentColor"></rect>
            <rect x="3" y="0" width="2" height="2" fill="currentColor"></rect>
            <rect x="6" y="0" width="2" height="2" fill="currentColor"></rect>
            <rect x="0" y="4" width="2" height="2" fill="currentColor"></rect>
            <rect x="6" y="4" width="2" height="2" fill="currentColor"></rect>
            <rect x="0" y="8" width="2" height="2" fill="currentColor"></rect>
            <rect x="3" y="8" width="2" height="2" fill="currentColor"></rect>
            <rect x="6" y="8" width="2" height="2" fill="currentColor"></rect>
          </svg>
          {cv.name}
        </a>

        <div class="bar-right">
          <div class="bar-links">
            <a href="#work">Work</a>
            <a href="#contact">Contact</a>
            <a href={cv.links.github} target="_blank" rel="noopener">GitHub</a>
          </div>

          <div class="theme-ctl">
            <span class="theme-labs">
              <span class="theme-lab lab-day">with me</span>
              <span class="theme-lab lab-night">without me</span>
            </span>
            <button
              class="fader"
              id="themeToggle"
              aria-label="Toggle day / night"
              title="With me, it's sunny. Without me… it gets complicated."
            >
              <span class="fader-thumb"></span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero" id="top">
      <div class="container">
        <p class="eyebrow"><span class="led"></span>{cv.location} · Available for work</p>
        <h1 class="hero-name">{cv.name}</h1>
        <p class="hero-role">{cv.role}</p>
        <p class="hero-tag">{cv.tagline}</p>
        <div class="btns">
          <a class="btn btn-primary" href={`mailto:${cv.email}`}>Get in touch</a>
          <a class="btn" href={cv.links.github} target="_blank" rel="noopener">GitHub</a>
          <a class="btn" href={cv.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </section>

    <main class="container">
      <!-- Work -->
      <section class="section" id="work" data-seq-target="work">
        <p class="sec-title">
          <span class="sec-no">01</span><span class="dash">—</span>Selected Work
        </p>
        <div class="grid">
          {
            cv.projects.map((p) => (
              <article class="card">
                <div class="card-strip">
                  <span class="led" />
                  {p.name.replace(/\s+/g, "-").toUpperCase()} · {p.meta} · {p.year}
                </div>
                <img
                  class="card-screen"
                  src={p.image}
                  alt={`${p.name} — screenshot`}
                  loading="lazy"
                />
                <h3>{p.name}</h3>
                <p>{p.description}</p>
                <ul class="tags">
                  {p.tech.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
                <div class="card-foot">
                  {p.demo && (
                    <a class="card-cta" href={p.demo} target="_blank" rel="noopener">
                      ▶ Live demo
                    </a>
                  )}
                  {p.link ? (
                    <a class="card-cta muted" href={p.link} target="_blank" rel="noopener">
                      Code →
                    </a>
                  ) : (
                    <span class="card-cta muted">Code private</span>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <!-- About -->
      <section class="section" id="about" data-seq-target="about">
        <p class="sec-title"><span class="sec-no">02</span><span class="dash">—</span>About</p>
        <p class="lead">{cv.about}</p>
      </section>

      <!-- Experience -->
      <section class="section" id="experience" data-seq-target="experience">
        <p class="sec-title"><span class="sec-no">03</span><span class="dash">—</span>Experience</p>
        {
          cv.experience.map((job) => (
            <div class="item">
              <div class="item-head">
                <h3 class="item-title">{job.title}</h3>
                <span class="item-meta">{job.period}</span>
              </div>
              <p class="item-sub">
                {job.company}
                <span class="item-where">· {job.type} · {job.where}</span>
              </p>
              <p class="item-desc">{job.description}</p>
            </div>
          ))
        }
      </section>

      <!-- Skills -->
      <section class="section" id="skills" data-seq-target="skills">
        <p class="sec-title"><span class="sec-no">04</span><span class="dash">—</span>Skills</p>
        <ul class="tags">
          {cv.skills.map((s) => <li class="tag">{s}</li>)}
        </ul>
      </section>

      <!-- Education -->
      <section class="section" id="education" data-seq-target="education">
        <p class="sec-title"><span class="sec-no">05</span><span class="dash">—</span>Education</p>
        {
          cv.education.map((ed) => (
            <div class="item">
              <div class="item-head">
                <h3 class="item-title">{ed.title}</h3>
                <span class="item-meta">{ed.period}</span>
              </div>
              <p class="item-sub">{ed.school}</p>
            </div>
          ))
        }
      </section>

      <!-- Contact -->
      <section class="section" id="contact" data-seq-target="contact">
        <p class="sec-title"><span class="sec-no">06</span><span class="dash">—</span>Contact</p>
        <p class="lead">
          Reach out at <a href={`mailto:${cv.email}`}>{cv.email}</a> — or find me on
          <a href={cv.links.github} target="_blank" rel="noopener">GitHub</a>.
        </p>
      </section>
    </main>

    <footer class="foot">
      <div class="container foot-inner">
        <span>{cv.name} — Bruit / Signal</span>
        <span>© {new Date().getFullYear()} · built as an instrument</span>
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  const root = document.documentElement;
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ---------- colours (refreshed on theme change) ----------
  let COL = { ink: "#16181a", muted: "#6b7076", bolt: "#eef1ff", overlay: "#dfe6ff" };
  function refreshColours() {
    const cs = getComputedStyle(root);
    const dark = root.dataset.theme === "dark";
    COL = {
      ink: cs.getPropertyValue("--ink").trim() || COL.ink,
      muted: cs.getPropertyValue("--muted").trim() || COL.muted,
      bolt: dark ? "#eef1ff" : "#20305a",
      overlay: dark ? "#eef2ff" : "#9fb2ff",
    };
  }
  refreshColours();

  // ---------- theme toggle ----------
  const toggle = document.getElementById("themeToggle");
  toggle &&
    toggle.addEventListener("click", () => {
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      try {
        localStorage.setItem("theme", next);
      } catch (e) {}
      refreshColours();
      window.__drawScene && window.__drawScene(0, 0); // instant repaint on toggle
    });

  // ---------- sky scenes: DAY (sun / clouds / birds) & NIGHT (moon / rain / lightning) ----------
  const cv = document.getElementById("sky");
  const ctx = cv.getContext("2d");
  const flashEl = document.getElementById("flash");
  let W = 0,
    H = 0,
    dpr = 1;
  let last = performance.now();
  const WIND = 0.16;
  let boost = 0;
  const isNight = () => root.dataset.theme === "dark";

  const drops = [],
    clouds = [],
    birds = [],
    stars = [];
  function seed() {
    drops.length = clouds.length = birds.length = stars.length = 0;
    const rainN = Math.min(340, Math.round((innerWidth * innerHeight) / 6200));
    for (let i = 0; i < rainN; i++) {
      const d = Math.random();
      drops.push({
        x: Math.random(),
        y: Math.random(),
        len: 9 + d * 17,
        vy: 0.55 + d * 0.95,
        a: 0.06 + d * 0.16,
        w: 0.6 + d * 0.9,
      });
    }
    const cloudN = Math.max(4, Math.round(innerWidth / 320));
    for (let i = 0; i < cloudN; i++) {
      clouds.push({
        x: Math.random() * 1.3 - 0.15,
        y: 0.05 + Math.random() * 0.4,
        s: 0.6 + Math.random() * 0.95,
        v: 0.006 + Math.random() * 0.013,
      });
    }
    for (let i = 0; i < 5; i++) {
      birds.push({
        x: Math.random(),
        y: 0.12 + Math.random() * 0.3,
        s: 8 + Math.random() * 6,
        v: 0.03 + Math.random() * 0.03,
        ph: Math.random() * 6.28,
      });
    }
    for (let i = 0; i < 46; i++) {
      stars.push({ x: Math.random(), y: Math.random() * 0.55, r: 0.5 + Math.random() * 1.1, tw: Math.random() * 6.28 });
    }
  }
  function size() {
    dpr = Math.min(2, devicePixelRatio || 1);
    W = cv.width = Math.floor(innerWidth * dpr);
    H = cv.height = Math.floor(innerHeight * dpr);
    cv.style.width = innerWidth + "px";
    cv.style.height = innerHeight + "px";
  }
  function fillSky(top, bottom) {
    const g = ctx.createLinearGradient(0, 0, 0, H);
    g.addColorStop(0, top);
    g.addColorStop(1, bottom);
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, W, H);
  }

  // ----- DAY -----
  function drawSun() {
    const sx = W * 0.82,
      sy = H * 0.18,
      R = 44 * dpr;
    const g = ctx.createRadialGradient(sx, sy, 0, sx, sy, R * 5);
    g.addColorStop(0, "rgba(255,246,198,0.9)");
    g.addColorStop(0.22, "rgba(255,236,160,0.32)");
    g.addColorStop(1, "rgba(255,236,160,0)");
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, W, H);
    ctx.beginPath();
    ctx.arc(sx, sy, R, 0, 6.2832);
    ctx.fillStyle = "#fff3b8";
    ctx.fill();
  }
  function drawCloud(cx, cy, s) {
    const u = 24 * dpr * s;
    ctx.fillStyle = "rgba(255,255,255,0.92)";
    const puffs = [
      [-1.7, 0.05, 0.95, 0.7],
      [-0.7, -0.5, 1.2, 1.0],
      [0.5, -0.55, 1.15, 0.95],
      [1.6, 0.0, 1.0, 0.78],
      [0, 0.1, 1.9, 0.9],
    ];
    for (const [ox, oy, rx, ry] of puffs) {
      ctx.beginPath();
      ctx.ellipse(cx + ox * u, cy + oy * u, rx * u, ry * u, 0, 0, 6.2832);
      ctx.fill();
    }
  }
  function drawBird(bx, by, s, flap) {
    const w = s * dpr;
    const lift = (Math.sin(flap) * 0.4 + 0.28) * w;
    ctx.strokeStyle = "rgba(34,48,66,0.7)";
    ctx.lineWidth = Math.max(1, 1.4 * dpr);
    ctx.beginPath();
    ctx.moveTo(bx - w, by - lift);
    ctx.quadraticCurveTo(bx - w * 0.4, by - lift * 0.15, bx, by);
    ctx.quadraticCurveTo(bx + w * 0.4, by - lift * 0.15, bx + w, by - lift);
    ctx.stroke();
  }
  function drawDay(dt, t) {
    fillSky("#8fc4ec", "#d9edf9");
    drawSun();
    for (const c of clouds) {
      c.x += c.v * dt;
      if (c.x > 1.35) c.x = -0.3;
      drawCloud(c.x * W, c.y * H, c.s);
    }
    for (const b of birds) {
      b.x += b.v * dt;
      if (b.x > 1.06) {
        b.x = -0.06;
        b.y = 0.12 + Math.random() * 0.3;
      }
      drawBird(b.x * W, b.y * H, b.s, t * 6 + b.ph);
    }
  }

  // ----- NIGHT -----
  function drawStars(t) {
    ctx.fillStyle = "#e2e8f6";
    for (const s of stars) {
      ctx.globalAlpha = 0.25 + 0.5 * (0.5 + 0.5 * Math.sin(t * 2 + s.tw));
      ctx.beginPath();
      ctx.arc(s.x * W, s.y * H, s.r * dpr, 0, 6.2832);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }
  function drawMoon() {
    const mx = W * 0.82,
      my = H * 0.18,
      R = 40 * dpr;
    const g = ctx.createRadialGradient(mx, my, 0, mx, my, R * 3.4);
    g.addColorStop(0, "rgba(210,220,245,0.3)");
    g.addColorStop(1, "rgba(210,220,245,0)");
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, W, H);
    ctx.beginPath();
    ctx.arc(mx, my, R, 0, 6.2832);
    ctx.fillStyle = "#e9edf7";
    ctx.fill();
    ctx.fillStyle = "rgba(150,162,190,0.35)";
    const craters = [
      [-0.32, -0.18, 0.22],
      [0.26, 0.12, 0.16],
      [0.05, -0.34, 0.12],
      [-0.12, 0.32, 0.14],
    ];
    for (const [ox, oy, r] of craters) {
      ctx.beginPath();
      ctx.arc(mx + ox * R, my + oy * R, r * R, 0, 6.2832);
      ctx.fill();
    }
  }
  function stepRain(dt) {
    const b = 1 + boost;
    ctx.strokeStyle = "rgba(220,228,244,0.6)";
    for (const d of drops) {
      const x = d.x * W,
        y = d.y * H;
      const len = d.len * dpr * (1 + boost * 0.5);
      ctx.globalAlpha = Math.min(0.8, d.a * b * 1.5);
      ctx.lineWidth = d.w * dpr;
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(x - WIND * len, y + len);
      ctx.stroke();
      d.y += d.vy * dt * b;
      d.x -= 0.014 * d.vy * dt;
      if (d.y > 1.03) {
        d.y = -0.03;
        d.x = Math.random();
      }
      if (d.x < -0.03) d.x = 1.03;
    }
    ctx.globalAlpha = 1;
    boost = Math.max(0, boost - dt * 1.3);
  }
  let bolt = null,
    nextStrike = 4;
  function strike() {
    if (reduce) return;
    boost = 1;
    let x = 0.14 + Math.random() * 0.72;
    const segs = [[x, 0]];
    let y = 0;
    const end = 0.55 + Math.random() * 0.2;
    while (y < end) {
      y += 0.04 + Math.random() * 0.05;
      x += (Math.random() - 0.5) * 0.1;
      segs.push([x, y]);
    }
    bolt = { segs, life: 1 };
    flashEl.style.background = "#eef2ff";
    flashEl.style.transition = "none";
    flashEl.style.opacity = "0.5";
    requestAnimationFrame(() => {
      flashEl.style.transition = "opacity 380ms ease-out";
      flashEl.style.opacity = "0";
    });
  }
  function drawBolt(dt) {
    if (!bolt) return;
    ctx.save();
    ctx.globalAlpha = Math.max(0, bolt.life);
    ctx.strokeStyle = "#eef1ff";
    ctx.lineWidth = 3 * dpr;
    ctx.shadowColor = "#eef1ff";
    ctx.shadowBlur = 12 * dpr;
    ctx.beginPath();
    ctx.moveTo(bolt.segs[0][0] * W, 0);
    for (const [sx, sy] of bolt.segs) ctx.lineTo(sx * W, sy * H);
    ctx.stroke();
    ctx.restore();
    bolt.life -= dt * 2.6;
    if (bolt.life <= 0) bolt = null;
  }
  function drawNight(dt, t) {
    fillSky("#0c1220", "#161d2c");
    drawStars(t);
    drawMoon();
    stepRain(dt);
    drawBolt(dt);
    nextStrike -= dt;
    if (nextStrike <= 0) {
      strike();
      nextStrike = 7 + Math.random() * 11;
    }
  }

  // ----- dispatch + loop -----
  function drawScene(dt, t) {
    if (isNight()) drawNight(dt, t);
    else drawDay(dt, t);
  }
  window.__drawScene = drawScene;
  seed();
  size();
  drawScene(0, 0); // static first frame (reduced-motion / hidden tab)
  addEventListener("resize", () => {
    size();
    seed();
    drawScene(0, 0);
  });
  if (!reduce) {
    const loop = (now) => {
      const dt = Math.min(0.05, (now - last) / 1000);
      last = now;
      if (!document.hidden) drawScene(dt, now / 1000);
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  }

  // ---------- sequencer nav ----------
  const cells = [...document.querySelectorAll(".seq [data-seq]")];
  cells.forEach((c) =>
    c.addEventListener("click", () =>
      document.getElementById(c.dataset.seq)?.scrollIntoView({ behavior: "smooth" })
    )
  );
  const targets = [...document.querySelectorAll("[data-seq-target]")];
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) {
          const id = en.target.getAttribute("data-seq-target");
          cells.forEach((c) => c.classList.toggle("active", c.dataset.seq === id));
        }
      });
    },
    { rootMargin: "-45% 0px -45% 0px" }
  );
  targets.forEach((t) => io.observe(t));

  // enable theme crossfade transitions after first paint
  requestAnimationFrame(() => root.classList.add("ready"));
</script>
