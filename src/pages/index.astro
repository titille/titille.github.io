---
import BaseLayout from "../layouts/BaseLayout.astro";
import PixelFlame from "../components/PixelFlame.astro";

// ─────────────────────────────────────────────────────────────
//  EDIT YOUR CV CONTENT HERE
//  Everything below is placeholder text — replace it with yours.
// ─────────────────────────────────────────────────────────────
const cv = {
  name: "Tristan Weber",
  role: "Software Developer",
  tagline:
    "I build fast, accessible web applications and interactive audio-visual toys — turning ideas into polished, playable products.",
  location: "France",
  email: "webertristan2000@gmail.com",
  links: {
    github: "https://github.com/titille",
    linkedin: "https://www.linkedin.com/in/your-handle",
  },

  about:
    "Short introduction about yourself. Talk about what you do, what you're passionate about, and what kind of role or projects you're looking for. Two or three sentences is plenty.",

  experience: [
    {
      title: "Job Title",
      company: "Company Name",
      period: "2023 — Present",
      description:
        "Describe your responsibilities and biggest achievements. Use numbers when you can (e.g. improved load time by 40%).",
    },
    {
      title: "Previous Job Title",
      company: "Previous Company",
      period: "2021 — 2023",
      description:
        "Another role. Keep each entry concise and focused on impact rather than a list of tasks.",
    },
  ],

  projects: [
    {
      name: "Rain to Hi-Hat",
      description:
        "A full-screen pixel-art soundscape — physically-modeled rain, swell, storm and wind — that morphs into a drum kit (hi-hat, kick, crash, riser) with a single knob. Every visible pixel event maps to an audible one, all in dependency-free vanilla JS on a real-time AudioWorklet.",
      tech: ["Web Audio", "AudioWorklet", "Pixel art"],
      demo: "/demos/rain-to-hihat/",
      // Source repo is private, so no public code link.
      link: null,
    },
    {
      name: "Rhythmic Spiral",
      description:
        "An interactive 3D visualization of one rhythm morphing into another. Beats travel as colored threads along a time-spiral, are auto-matched by shortest path, and drive live audio synthesis — 6 timbres, 5 scales, and 30+ presets.",
      tech: ["Three.js", "JavaScript", "Web Audio"],
      demo: "/demos/rhythmic-spiral/",
      link: "https://github.com/titille/rhythmic-spiral",
    },
  ],

  skills: [
    "JavaScript",
    "TypeScript",
    "React",
    "Astro",
    "Node.js",
    "HTML & CSS",
    "Git",
    "Figma",
  ],

  education: [
    {
      title: "Your Degree",
      school: "University / School Name",
      period: "2018 — 2021",
    },
  ],
};
---

<BaseLayout title={`${cv.name} — ${cv.role}`} description={cv.tagline}>
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a class="nav-brand" href="#top">
        <PixelFlame size="1.15em" />
        {cv.name}
      </a>
      <div class="nav-links">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
        <a href={cv.links.github} target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header class="hero" id="top">
    <div class="container">
      <PixelFlame size="68px" class="hero-flame" />
      <p class="eyebrow">{cv.location} · Available for work</p>
      <h1 class="hero-name">{cv.name}</h1>
      <p class="role">{cv.role}</p>
      <p class="tagline">{cv.tagline}</p>
      <div class="hero-links">
        <a class="btn btn-primary" href={`mailto:${cv.email}`}>Get in touch</a>
        <a class="btn" href={cv.links.github} target="_blank" rel="noopener">GitHub</a>
        <a class="btn" href={cv.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>
    <div class="flame-strip" role="presentation"></div>
  </header>

  <main class="container">
    <!-- About -->
    <section id="about">
      <p class="section-title">About</p>
      <p class="lead">{cv.about}</p>
    </section>

    <!-- Experience -->
    <section id="experience">
      <p class="section-title">Experience</p>
      {
        cv.experience.map((job) => (
          <div class="item">
            <div class="item-head">
              <h3 class="item-title">{job.title}</h3>
              <span class="item-meta">{job.period}</span>
            </div>
            <p class="item-sub">{job.company}</p>
            <p class="item-desc">{job.description}</p>
          </div>
        ))
      }
    </section>

    <!-- Projects -->
    <section id="projects">
      <p class="section-title">Projects</p>
      <div class="grid">
        {
          cv.projects.map((project) => (
            <div class="card">
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <ul class="tags card-tags">
                {project.tech.map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>
              <div class="card-actions">
                {project.demo && (
                  <a class="card-cta" href={project.demo} target="_blank" rel="noopener">
                    ▶ Live demo
                  </a>
                )}
                {project.link ? (
                  <a
                    class="card-cta card-cta-muted"
                    href={project.link}
                    target="_blank"
                    rel="noopener"
                  >
                    Code →
                  </a>
                ) : (
                  <span class="card-cta card-cta-muted">🔒 Code private</span>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Skills -->
    <section id="skills">
      <p class="section-title">Skills</p>
      <ul class="tags">
        {cv.skills.map((skill) => <li class="tag">{skill}</li>)}
      </ul>
    </section>

    <!-- Education -->
    <section id="education">
      <p class="section-title">Education</p>
      {
        cv.education.map((ed) => (
          <div class="item">
            <div class="item-head">
              <h3 class="item-title">{ed.title}</h3>
              <span class="item-meta">{ed.period}</span>
            </div>
            <p class="item-sub">{ed.school}</p>
          </div>
        ))
      }
    </section>

    <!-- Contact -->
    <section id="contact">
      <p class="section-title">Contact</p>
      <p class="lead">
        Feel free to reach out at <a href={`mailto:${cv.email}`}>{cv.email}</a>.
      </p>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span><PixelFlame size="1.1em" /> {cv.name}</span>
      <span class="footer-meta">© {new Date().getFullYear()} · Built with Astro + pixels</span>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero {
    padding: 3.5rem 0 0;
    position: relative;
    background:
      radial-gradient(
        55% 90% at 12% -10%,
        color-mix(in srgb, var(--flame-3) 22%, transparent),
        transparent 70%
      );
  }

  .hero-flame {
    filter: drop-shadow(3px 3px 0 rgba(0, 0, 0, 0.12));
    margin-bottom: 1rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-size: 0.82rem;
    margin: 0 0 0.6rem;
  }

  .hero-name {
    font-family: var(--font-pixel);
    font-weight: 700;
    font-size: clamp(2.8rem, 9vw, 4.6rem);
    line-height: 0.95;
    margin: 0;
    color: var(--ink);
  }

  .role {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0.7rem 0 0.6rem;
  }

  .tagline {
    font-size: 1.12rem;
    color: var(--ink);
    max-width: 36rem;
    margin: 0 0 1.9rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding-bottom: 3.2rem;
  }

  /* Pixel-dithered flame strip */
  .flame-strip {
    height: 16px;
    background-image:
      /* checkerboard dither for pixel texture */
      conic-gradient(
        rgba(0, 0, 0, 0.16) 90deg,
        transparent 0 180deg,
        rgba(0, 0, 0, 0.16) 0 270deg,
        transparent 0
      ),
      /* hard-stop flame bands */
        linear-gradient(
          90deg,
          var(--flame-1) 0 20%,
          var(--flame-2) 20% 40%,
          var(--flame-3) 40% 60%,
          var(--flame-4) 60% 80%,
          var(--flame-5) 80% 100%
        );
    background-size:
      6px 6px,
      100% 100%;
    border-top: 2px solid var(--edge);
    border-bottom: 2px solid var(--edge);
  }

  .lead {
    font-size: 1.05rem;
    max-width: 44rem;
  }

  /* Footer */
  .site-footer {
    border-top: 2px solid var(--edge);
    margin-top: 1rem;
    padding: 1.6rem 0 2.6rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .footer-meta {
    color: var(--muted);
  }
</style>
