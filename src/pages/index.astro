---
import BaseLayout from "../layouts/BaseLayout.astro";

// ─────────────────────────────────────────────────────────────
//  EDIT YOUR CV CONTENT HERE
// ─────────────────────────────────────────────────────────────
const cv = {
  name: "Tristan Weber",
  role: "AI / Machine Learning Engineer",
  tagline:
    "ML / AI engineer — I build deep-learning models for time-series and data, and generative, interactive audio-visual instruments that turn noise into rhythm.",
  location: "Paris, France",
  email: "webertristan2000@gmail.com",
  links: {
    github: "https://github.com/titille",
    linkedin: "https://www.linkedin.com/in/tristan-weber-173158208/",
  },

  about:
    "I'm an AI / machine-learning engineer based in Paris, with an M2 in Applied Mathematics & Data Science from Paris 1 Panthéon-Sorbonne. I've built deep-learning models for time-series and data-quality analysis (Bureau Veritas, RTE) and, at Arrago, an AI platform that automates document analysis for reverse-mortgage files. On the side I make generative, interactive audio-visual instruments — a few are below.",

  experience: [
    {
      title: "AI Software Engineer",
      company: "Arrago",
      type: "Internship",
      where: "Paris",
      period: "Feb 2026 — Present",
      description:
        "Built an internal web app where sales and analysts log in to assemble and analyze reverse-mortgage (prêt viager hypothécaire) case files. Designed AI workflows that automatically pull the required documents, analyze bank statements, and flag inconsistencies across a file's paperwork.",
    },
    {
      title: "Machine Learning / Deep Learning Engineer",
      company: "Bureau Veritas — Marine & Offshore",
      type: "Internship",
      where: "Paris La Défense",
      period: "Apr 2025 — Oct 2025",
      description:
        "Time-series prediction on CFD sloshing simulations. Built ML/DL models in Python (XGBoost, MLP, LSTM) and ran training, optimization and fine-tuning with PyTorch / Keras and Optuna (hyperparameter search, validation).",
    },
    {
      title: "Data Quality / Telemetry Analyst",
      company: "RTE — Réseau de Transport d'Électricité",
      type: "Internship",
      where: "Paris La Défense",
      period: "Apr 2023 — Sep 2023",
      description:
        "Analyzed data quality and transmission losses on grid telemetry. Extracted data on Linux, then cleaned, ran consistency/completeness checks and anomaly detection in Python, reconciled missing telemetry via correlations and loss scenarios, and delivered usable datasets.",
    },
    {
      title: "Mathematics Tutor (MIASHS)",
      company: "Université Paris 1 Panthéon-Sorbonne",
      type: "Part-time",
      where: "Paris",
      period: "Sep 2020 — Apr 2023",
      description:
        "Tutored first-year MIASHS students in Analysis, Algebra, Probability and Python — methodology coaching, exercise correction and exam prep.",
    },
  ],

  projects: [
    {
      name: "Rain to Hi-Hat",
      meta: "INSTRUMENT",
      year: "2025",
      image: "/img/rain-to-hihat.png",
      description:
        "A full-screen pixel-art soundscape — physically-modeled rain, swell, storm and wind — that morphs into a drum kit with a single knob. Every visible pixel event maps to an audible one, in dependency-free vanilla JS on a real-time AudioWorklet.",
      tech: ["Web Audio", "AudioWorklet", "DSP"],
      demo: "/demos/rain-to-hihat/",
      link: null,
    },
    {
      name: "Rhythmic Spiral",
      meta: "VISUALIZER",
      year: "2025",
      image: "/img/rhythmic-spiral.png",
      description:
        "An interactive 3D visualization of one rhythm morphing into another. Beats travel as colored threads along a time-spiral, auto-matched by shortest path, driving live audio synthesis — 6 timbres, 5 scales, 30+ presets.",
      tech: ["Three.js", "JavaScript", "Web Audio"],
      demo: "/demos/rhythmic-spiral/",
      link: "https://github.com/titille/rhythmic-spiral",
    },
  ],

  skills: [
    "Python",
    "PyTorch",
    "Keras",
    "Machine Learning",
    "Deep Learning",
    "LLMs",
    "Document AI",
    "Time-Series Forecasting",
    "XGBoost",
    "Optuna",
    "Pandas / NumPy",
    "Data Analysis",
    "JavaScript / TypeScript",
    "Web Audio / DSP",
    "Three.js",
    "Git · Linux",
  ],

  education: [
    {
      title: "M2 · Applied Mathematics & Data Science (MMMEF)",
      school: "Université Paris 1 Panthéon-Sorbonne",
      period: "2022 — 2023",
    },
    {
      title: "Bachelor's · Mathematics & Computer Science (MIASHS)",
      school: "Université Paris 1 Panthéon-Sorbonne",
      period: "2018 — 2021",
    },
  ],
};

const sections = [
  { id: "work", label: "Work" },
  { id: "about", label: "About" },
  { id: "experience", label: "Exp" },
  { id: "skills", label: "Skills" },
  { id: "education", label: "Edu" },
  { id: "contact", label: "Contact" },
];
---

<BaseLayout title={`${cv.name} — ${cv.role}`} description={cv.tagline}>
  <!-- Sequencer nav -->
  <nav class="seq" aria-label="Section navigation">
    {
      sections.map((s) => (
        <button data-seq={s.id} aria-label={s.label}>
          <span class="seq-label">{s.label}</span>
        </button>
      ))
    }
  </nav>

  <div class="wrap">
    <!-- Instrument bar -->
    <header class="bar">
      <div class="bar-inner">
        <a class="brand" href="#top">
          <svg class="brand-mark" width="16" height="20" viewBox="0 0 8 10" aria-hidden="true">
            <rect x="0" y="0" width="2" height="2" fill="currentColor"></rect>
            <rect x="3" y="0" width="2" height="2" fill="currentColor"></rect>
            <rect x="6" y="0" width="2" height="2" fill="currentColor"></rect>
            <rect x="0" y="4" width="2" height="2" fill="currentColor"></rect>
            <rect x="6" y="4" width="2" height="2" fill="currentColor"></rect>
            <rect x="0" y="8" width="2" height="2" fill="currentColor"></rect>
            <rect x="3" y="8" width="2" height="2" fill="currentColor"></rect>
            <rect x="6" y="8" width="2" height="2" fill="currentColor"></rect>
          </svg>
          {cv.name}
        </a>

        <div class="bar-right">
          <div class="morph" title="Turn: rain ⇄ signal">
            <span class="morph-pole left on" id="poleL"><b>Pluie</b></span>
            <svg
              class="knob"
              id="knob"
              viewBox="0 0 44 44"
              role="slider"
              tabindex="0"
              aria-label="Morph the page from rain to signal"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="35"
            >
              <circle class="dial" cx="22" cy="22" r="17"></circle>
              <line class="tick" x1="22" y1="2.5" x2="22" y2="5.5"></line>
              <line class="tick" x1="7.2" y1="14" x2="9.8" y2="15.5"></line>
              <line class="tick" x1="36.8" y1="14" x2="34.2" y2="15.5"></line>
              <g id="knobInd"><line class="ind" x1="22" y1="22" x2="22" y2="9"></line></g>
            </svg>
            <span class="morph-pole right" id="poleR"><b>Signal</b></span>
          </div>

          <div class="bar-links">
            <a href="#work">Work</a>
            <a href="#contact">Contact</a>
            <a href={cv.links.github} target="_blank" rel="noopener">GitHub</a>
          </div>

          <button class="fader" id="themeToggle" aria-label="Toggle theme" title="Toggle light / dark">
            <span class="fader-thumb"></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero" id="top">
      <div class="container">
        <p class="eyebrow"><span class="led"></span>{cv.location} · Available for work</p>
        <h1 class="hero-name">{cv.name}</h1>
        <p class="hero-role">{cv.role}</p>
        <p class="hero-tag">{cv.tagline}</p>
        <div class="btns">
          <a class="btn btn-primary" href={`mailto:${cv.email}`}>Get in touch</a>
          <a class="btn" href={cv.links.github} target="_blank" rel="noopener">GitHub</a>
          <a class="btn" href={cv.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        </div>
        <figure class="morphviz">
          <figcaption class="mv-labels">
            <span>◍ PLUIE <em>· rain</em></span>
            <span class="mv-mode" id="mvMode">— scattered noise</span>
            <span><em>groove ·</em> SIGNAL ▦</span>
          </figcaption>
          <canvas id="mviz" class="mv-canvas" aria-hidden="true"></canvas>
          <p class="mv-hint">
            turn the <b>MORPH</b> knob ↑ (or drag here) — watch the rain lock into a hi-hat groove
          </p>
        </figure>
      </div>
    </section>

    <main class="container">
      <!-- Work -->
      <section class="section" id="work" data-seq-target="work">
        <p class="sec-title">
          <span class="sec-no">01</span><span class="dash">—</span>Selected Work
        </p>
        <div class="grid">
          {
            cv.projects.map((p) => (
              <article class="card">
                <div class="card-strip">
                  <span class="led" />
                  {p.name.replace(/\s+/g, "-").toUpperCase()} · {p.meta} · {p.year}
                </div>
                <img
                  class="card-screen"
                  src={p.image}
                  alt={`${p.name} — screenshot`}
                  loading="lazy"
                />
                <h3>{p.name}</h3>
                <p>{p.description}</p>
                <ul class="tags">
                  {p.tech.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
                <div class="card-foot">
                  {p.demo && (
                    <a class="card-cta" href={p.demo} target="_blank" rel="noopener">
                      ▶ Live demo
                    </a>
                  )}
                  {p.link ? (
                    <a class="card-cta muted" href={p.link} target="_blank" rel="noopener">
                      Code →
                    </a>
                  ) : (
                    <span class="card-cta muted">Code private</span>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <!-- About -->
      <section class="section" id="about" data-seq-target="about">
        <p class="sec-title"><span class="sec-no">02</span><span class="dash">—</span>About</p>
        <p class="lead">{cv.about}</p>
      </section>

      <!-- Experience -->
      <section class="section" id="experience" data-seq-target="experience">
        <p class="sec-title"><span class="sec-no">03</span><span class="dash">—</span>Experience</p>
        {
          cv.experience.map((job) => (
            <div class="item">
              <div class="item-head">
                <h3 class="item-title">{job.title}</h3>
                <span class="item-meta">{job.period}</span>
              </div>
              <p class="item-sub">
                {job.company}
                <span class="item-where">· {job.type} · {job.where}</span>
              </p>
              <p class="item-desc">{job.description}</p>
            </div>
          ))
        }
      </section>

      <!-- Skills -->
      <section class="section" id="skills" data-seq-target="skills">
        <p class="sec-title"><span class="sec-no">04</span><span class="dash">—</span>Skills</p>
        <ul class="tags">
          {cv.skills.map((s) => <li class="tag">{s}</li>)}
        </ul>
      </section>

      <!-- Education -->
      <section class="section" id="education" data-seq-target="education">
        <p class="sec-title"><span class="sec-no">05</span><span class="dash">—</span>Education</p>
        {
          cv.education.map((ed) => (
            <div class="item">
              <div class="item-head">
                <h3 class="item-title">{ed.title}</h3>
                <span class="item-meta">{ed.period}</span>
              </div>
              <p class="item-sub">{ed.school}</p>
            </div>
          ))
        }
      </section>

      <!-- Contact -->
      <section class="section" id="contact" data-seq-target="contact">
        <p class="sec-title"><span class="sec-no">06</span><span class="dash">—</span>Contact</p>
        <p class="lead">
          Reach out at <a href={`mailto:${cv.email}`}>{cv.email}</a> — or find me on
          <a href={cv.links.github} target="_blank" rel="noopener">GitHub</a>.
        </p>
      </section>
    </main>

    <footer class="foot">
      <div class="container foot-inner">
        <span>{cv.name} — Bruit / Signal</span>
        <span>© {new Date().getFullYear()} · built as an instrument</span>
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  const root = document.documentElement;
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ---------- colours (refreshed on theme change) ----------
  let COL = { ink: "#16181a", red: "#d40000", cobalt: "#0044bb", muted: "#6b7076" };
  function refreshColours() {
    const cs = getComputedStyle(root);
    COL = {
      ink: cs.getPropertyValue("--ink").trim() || COL.ink,
      red: cs.getPropertyValue("--red").trim() || COL.red,
      cobalt: cs.getPropertyValue("--cobalt").trim() || COL.cobalt,
      muted: cs.getPropertyValue("--muted").trim() || COL.muted,
    };
  }
  refreshColours();

  // ---------- morph state ----------
  let morph = 0.35;
  const knob = document.getElementById("knob");
  const knobInd = document.getElementById("knobInd");
  const poleL = document.getElementById("poleL");
  const poleR = document.getElementById("poleR");
  const mvMode = document.getElementById("mvMode");

  function applyMorph(v) {
    morph = Math.max(0, Math.min(1, v));
    root.style.setProperty("--morph", morph.toFixed(3));
    root.style.setProperty("--wght", String(Math.round(320 + morph * 430)));
    root.style.setProperty(
      "--ease",
      morph > 0.45 ? `steps(${Math.round(4 + morph * 9)}, end)` : "cubic-bezier(0.2,0.7,0.3,1)"
    );
    if (knobInd) knobInd.setAttribute("transform", `rotate(${-135 + morph * 270} 22 22)`);
    if (knob) knob.setAttribute("aria-valuenow", String(Math.round(morph * 100)));
    poleL && poleL.classList.toggle("on", morph < 0.5);
    poleR && poleR.classList.toggle("on", morph >= 0.5);
    if (mvMode)
      mvMode.textContent =
        morph < 0.2
          ? "— scattered rain"
          : morph < 0.55
            ? "— quantizing…"
            : morph < 0.9
              ? "— locking to the grid"
              : "— 16-step groove";
  }
  applyMorph(morph);

  // knob interactions
  if (knob) {
    let dragging = false;
    knob.addEventListener("pointerdown", (e) => {
      dragging = true;
      knob.setPointerCapture(e.pointerId);
    });
    knob.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      applyMorph(morph - e.movementY * 0.006 + e.movementX * 0.003);
    });
    knob.addEventListener("pointerup", () => (dragging = false));
    knob.addEventListener(
      "wheel",
      (e) => {
        e.preventDefault();
        applyMorph(morph - e.deltaY * 0.0012);
      },
      { passive: false }
    );
    knob.addEventListener("keydown", (e) => {
      const k = e.key;
      if (k === "ArrowUp" || k === "ArrowRight") applyMorph(morph + 0.05);
      else if (k === "ArrowDown" || k === "ArrowLeft") applyMorph(morph - 0.05);
      else if (k === "Home") applyMorph(0);
      else if (k === "End") applyMorph(1);
      else return;
      e.preventDefault();
    });
  }

  // ---------- theme toggle ----------
  const toggle = document.getElementById("themeToggle");
  toggle &&
    toggle.addEventListener("click", () => {
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      try {
        localStorage.setItem("theme", next);
      } catch (e) {}
      refreshColours();
    });

  // ---------- the clock (92 BPM, 16th notes) ----------
  const BPM = 92;
  const STEP = 60 / BPM / 4;
  let step = 0,
    acc = 0,
    last = performance.now();

  // ---------- hero morph visualizer: rain (PLUIE) → hi-hat groove (SIGNAL) ----------
  // Screen is always dark, so use fixed light-on-dark colours (not theme tokens).
  const S_GUIDE = "#8d9198",
    S_INK = "#e8eaf0",
    S_COBALT = "#7c97ff",
    S_RED = "#ff5147";
  const PAT = [2, 1, 1, 1, 2, 1, 1, 1, 2, 1, 1, 1, 2, 1, 1, 1]; // 2 = accent (beat)

  const mviz = document.getElementById("mviz");
  const mctx = mviz.getContext("2d");
  let mw = 0,
    mh = 0,
    dpr = 1;
  const rain = [];
  function seedRain() {
    rain.length = 0;
    for (let i = 0; i < 64; i++) {
      rain.push({
        col: (i * 5) % 16,
        rx: Math.random(),
        y: Math.random(),
        vy: 0.45 + Math.random() * 0.55,
        len: 7 + Math.random() * 11,
      });
    }
  }
  function sizeMviz() {
    dpr = Math.min(2, devicePixelRatio || 1);
    const r = mviz.getBoundingClientRect();
    mw = mviz.width = Math.max(1, Math.floor(r.width * dpr));
    mh = mviz.height = Math.max(1, Math.floor(r.height * dpr));
  }
  let flash = 0,
    flashCol = 0;
  function onStep() {
    if (PAT[step] === 2 && morph > 0.25) {
      flash = 1;
      flashCol = step;
    }
  }
  function drawMviz(dt) {
    const m = morph;
    mctx.clearRect(0, 0, mw, mh);
    const colW = mw / 16;
    const yb = mh * 0.76; // sequencer baseline
    flash = Math.max(0, flash - dt * 3.2);

    // SIGNAL layer — grid guides, playhead band, step cells (alpha ∝ m)
    mctx.lineWidth = 1 * dpr;
    for (let i = 0; i < 16; i++) {
      const cx = (i + 0.5) * colW;
      mctx.globalAlpha = m * 0.13;
      mctx.strokeStyle = S_GUIDE;
      mctx.beginPath();
      mctx.moveTo(cx, mh * 0.14);
      mctx.lineTo(cx, yb);
      mctx.stroke();
    }
    if (m > 0.06) {
      mctx.globalAlpha = m * 0.2;
      mctx.fillStyle = S_COBALT;
      mctx.fillRect(step * colW, mh * 0.12, colW, yb - mh * 0.12);
    }
    for (let i = 0; i < 16; i++) {
      const cx = (i + 0.5) * colW;
      const accent = PAT[i] === 2;
      const active = i === step;
      let size = (accent ? 5 : 3) * dpr;
      let alpha = m * (accent ? 0.9 : 0.5);
      let color = S_INK;
      if (active && m > 0.06) {
        size += 2.5 * dpr;
        alpha = Math.min(1, alpha + 0.35);
        color = S_COBALT;
      }
      if (active && accent && m > 0.25) color = S_RED;
      mctx.globalAlpha = alpha;
      mctx.fillStyle = color;
      mctx.fillRect(cx - size / 2, yb - size / 2, size, size);
    }
    if (flash > 0) {
      mctx.globalAlpha = flash * m * 0.85;
      mctx.strokeStyle = S_RED;
      mctx.lineWidth = 2 * dpr;
      mctx.beginPath();
      mctx.arc((flashCol + 0.5) * colW, yb, (1 - flash) * 20 * dpr + 4 * dpr, 0, 6.2832);
      mctx.stroke();
    }

    // PLUIE layer — rain streaks (alpha ∝ 1−m), drifting from random x toward columns
    mctx.lineWidth = 1.6 * dpr;
    mctx.strokeStyle = S_COBALT;
    for (const d of rain) {
      const homeX = (d.col + 0.5) * colW;
      const x = d.rx * mw * (1 - m) + homeX * m;
      const y = d.y * mh;
      mctx.globalAlpha = 0.1 + (1 - m) * 0.42;
      mctx.beginPath();
      mctx.moveTo(x, y);
      mctx.lineTo(x, y + d.len * dpr * (1 - m * 0.7));
      mctx.stroke();
    }
    mctx.globalAlpha = 1;
  }
  function stepRain(dt) {
    for (const d of rain) {
      d.y += d.vy * dt * (1.1 - morph * 0.55);
      if (d.y > 1.05) {
        d.y = -0.05;
        d.rx = Math.random();
      }
    }
  }

  // ---------- loop ----------
  function frame(now) {
    const dt = Math.min(0.05, (now - last) / 1000);
    last = now;
    if (!document.hidden && !reduce) {
      acc += dt;
      while (acc >= STEP) {
        acc -= STEP;
        step = (step + 1) % 16;
        onStep();
      }
      stepRain(dt);
      drawMviz(dt);
    }
    requestAnimationFrame(frame);
  }

  seedRain();
  sizeMviz();
  drawMviz(0); // static first frame (reduced-motion + hidden-tab)
  addEventListener("resize", () => {
    sizeMviz();
    drawMviz(0);
  });
  if (!reduce) requestAnimationFrame(frame);

  // drag horizontally on the visualizer to morph (in addition to the knob)
  {
    let dv = false;
    mviz.style.cursor = "ew-resize";
    mviz.addEventListener("pointerdown", (e) => {
      dv = true;
      mviz.setPointerCapture(e.pointerId);
    });
    mviz.addEventListener("pointermove", (e) => {
      if (dv) applyMorph(morph + e.movementX * 0.0045);
    });
    mviz.addEventListener("pointerup", () => (dv = false));
  }

  // ---------- sequencer nav ----------
  const cells = [...document.querySelectorAll(".seq [data-seq]")];
  cells.forEach((c) =>
    c.addEventListener("click", () =>
      document.getElementById(c.dataset.seq)?.scrollIntoView({ behavior: "smooth" })
    )
  );
  const targets = [...document.querySelectorAll("[data-seq-target]")];
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) {
          const id = en.target.getAttribute("data-seq-target");
          cells.forEach((c) => c.classList.toggle("active", c.dataset.seq === id));
        }
      });
    },
    { rootMargin: "-45% 0px -45% 0px" }
  );
  targets.forEach((t) => io.observe(t));

  // enable theme crossfade transitions after first paint
  requestAnimationFrame(() => root.classList.add("ready"));
</script>
